# =================================================================
# QUICK START
# =================================================================
# For local development:
#   1. Copy this file to .env.local:
#      cp .env.example .env.local
#   2. Add your actual API keys below
#   3. Run: npm run dev
#
# For production deployment:
#   1. Do NOT commit actual secrets to this file
#   2. Set environment variables in your deployment platform
#   3. See SECRETS_MANAGEMENT.md for detailed instructions

# =================================================================
# REQUIRED VARIABLES
# =================================================================

# Google Maps API Key (OPTIONAL but Recommended for Production)
# ------------------------------------------------------------
# Get your key from: https://console.cloud.google.com/apis/credentials
#
# How to create a Google Maps API Key:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Click "Create Credentials" > "API Key"
# 3. Click on the created API key to edit restrictions
# 4. Under "Application restrictions":
#    - For local dev: Add http://localhost:5173/*
#    - For production: Add https://yourdomain.com/*
# 5. Under "API restrictions":
#    - Select "Restrict key" and check:
#      ✓ Maps JavaScript API
#      ✓ Geocoding API
#      ✓ Places API (optional)
# 6. Set usage quotas and billing alerts
#
# If not provided, the app will automatically use OpenStreetMap
# (free, no API key required) for basic mapping functionality.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =================================================================
# OPTIONAL VARIABLES
# =================================================================

# Application Environment
# ---------------------
# Values: development, test, production
# Default: development
VITE_APP_ENV=development

# Debug Mode
# ----------
# Enable verbose logging for debugging (only use in non-production)
# Values: true, false
# Default: false
VITE_ENABLE_DEBUG=false

# Log Level
# ---------
# Controls logging verbosity
# Values: debug, info, warn, error
# Default: info
VITE_LOG_LEVEL=info

# =================================================================
# API CONFIGURATION (Optional)
# =================================================================
# These are optional - the app uses sensible defaults if not specified

# FuelEconomy.gov API Base URL
# Default: https://www.fueleconomy.gov/ws/rest
# VITE_FUELECONOMY_API_URL=https://www.fueleconomy.gov/ws/rest

# NHTSA VPIC API Base URL
# Default: https://vpic.nhtsa.dot.gov/api
# VITE_NHTSA_API_URL=https://vpic.nhtsa.dot.gov/api

# CORS Proxy URL (if needed for API requests)
# WARNING: Only use trusted CORS proxies
# Default: https://corsproxy.io/?
# VITE_CORS_PROXY_URL=https://corsproxy.io/?

# =================================================================
# BACKEND PROXY CONFIGURATION (Production)
# =================================================================
# Backend proxy server URL
# Replace with your actual backend URL in production
VITE_API_BASE_URL=https://api.yourdomain.com/api/fueleconomy

# Use backend proxy instead of direct API calls
# Set to 'true' to use backend proxy, 'false' to use direct API
# Development: 'false' (uses Vite proxy) or 'true' (uses backend)
# Production: 'true' (uses backend proxy)
VITE_USE_PROXY=true

# API Timeout (milliseconds)
# Default: 10000 (10 seconds)
VITE_API_TIMEOUT=10000

# =================================================================
# FEATURE FLAGS (Optional)
# =================================================================

# Enable Mock Data
# ----------------
# Use mock data for development/testing instead of real API calls
# Values: true, false
# Default: false
VITE_ENABLE_MOCK_DATA=false

# Performance Monitoring
# ----------------------
# Enable performance metrics collection
# Values: true, false
# Default: false
VITE_ENABLE_PERFORMANCE_MONITORING=false

# Error Tracking
# --------------
# Enable error reporting to monitoring services
# Values: true, false
# Default: false
VITE_ENABLE_ERROR_TRACKING=false

# =================================================================
# SECURITY SETTINGS (Production Only)
# =================================================================

# Content Security Policy Mode
# -----------------------------
# Values: strict, relaxed, development
# Default: strict (production)
VITE_CSP_MODE=strict

# =================================================================
# ANALYTICS & MONITORING (Optional)
# =================================================================

# Enable Analytics
# ----------------
# Enable analytics tracking (Google Analytics, etc.)
# Values: true, false
# Default: false
VITE_ENABLE_ANALYTICS=false

# Sentry DSN (Error Monitoring)
# -----------------------------
# If using Sentry for error tracking, add your DSN here
# Get it from: https://sentry.io/
# VITE_SENTRY_DSN=your_sentry_dsn_here

# =================================================================
# TESTING CONFIGURATION (Only for .env.test)
# =================================================================

# Test Mode
# ---------
# Indicates tests are running
# Values: true, false
VITE_TEST_MODE=false

# Mock External APIs
# ------------------
# Mock all external API calls in tests
# Values: true, false
VITE_MOCK_EXTERNAL_APIS=false

# Test Async Timeout (milliseconds)
# ----------------------------------
# Timeout for async test operations
# Default: 10000 (10 seconds)
VITE_TEST_ASYNC_TIMEOUT=10000

# =================================================================
# PRODUCTION DEPLOYMENT NOTES
# =================================================================
#
# For production deployments:
#
# 1. DO NOT commit actual API keys to this file
# 2. Set environment variables in your deployment platform:
#    - Vercel: Project Settings > Environment Variables
#    - Netlify: Site Settings > Build & Deploy > Environment
#    - AWS: Elastic Beanstalk / EC2 / Lambda environment variables
#    - Docker: Use -e flag or docker-compose.yml
#    - Kubernetes: Use ConfigMaps and Secrets
#
# 3. All environment variables must start with VITE_ prefix
#    to be accessible in the browser (Vite requirement)
#
# 4. See PRODUCTION_DEPLOYMENT.md for detailed deployment guides
#
# 5. See API_KEY_MANAGEMENT.md for API key security best practices

# =================================================================
# TROUBLESHOOTING
# =================================================================
#
# Issue: "API key invalid"
# Solution: Check that your key has the required APIs enabled
#
# Issue: "CORS error"
# Solution: Ensure your API key has correct referrer restrictions
#
# Issue: "Environment variable not defined"
# Solution: Restart dev server after adding variables to .env.local
#
# Issue: "Build fails with missing env var"
# Solution: Check vite.config.js validation logs for specific errors
