# Backend Environment Configuration
# ========================================
# Copy this file to .env and fill in your actual values

# =================================================================
# SERVER CONFIGURATION
# =================================================================
# Port for the backend server
PORT=3000

# Node environment
NODE_ENV=development
#Use NODE_ENV=production only in the actual deployed environment (server/container/hosting platform), not as the default in the shared example file.

# =================================================================
# EPA FUELECONOMY.GOV API
# =================================================================
# Base URL for EPA FuelEconomy.gov API
FUELECONOMY_API_URL=https://www.fueleconomy.gov/ws/rest

# User agent for API requests (identifies your application)
USER_AGENT=FuelGuard-Backend/1.0

# API timeout in milliseconds
API_TIMEOUT=10000

# =================================================================
# SECURITY CONFIGURATION
# =================================================================
# Rate limiting: max requests per window
RATE_LIMIT_MAX=10

# Rate limiting: window duration in milliseconds (1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Enable CORS for frontend (comma-separated list of allowed origins)
# Example: http://localhost:5173,https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,https://localhost:5173

# =================================================================
# CACHING CONFIGURATION
# =================================================================
# Enable response caching
ENABLE_CACHE=true

# Cache TTL in seconds (30 minutes default)
CACHE_TTL=1800

# Maximum number of cache entries
CACHE_MAX_ENTRIES=1000

# =================================================================
# LOGGING CONFIGURATION
# =================================================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable detailed logging (only for development)
ENABLE_DEBUG_LOGGING=true

# =================================================================
# SECURITY HEADERS
# =================================================================
# Enable HSTS (HTTP Strict Transport Security)
ENABLE_HSTS=false

# HSTS max-age in seconds (6 months default)
HSTS_MAX_AGE=15768000

# =================================================================
# PRODUCTION SETTINGS
# =================================================================
# In production, set NODE_ENV=production and:
# - Set ENABLE_HSTS=true
# - Set ENABLE_DEBUG_LOGGING=false
# - Set CORS_ORIGINS to your actual domain(s)
# - Use a reverse proxy (nginx, Apache) for SSL
